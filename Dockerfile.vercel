FROM python:3.12-slim-bullseye

ENV DEBIAN_FRONTEND=noninteractive

WORKDIR /workspace

# Copy the whole monorepo structure
COPY . .

# Install FastAPI and uvicorn dependencies
RUN pip install --no-cache-dir fastapi uvicorn python-multipart

# Install the markitdown package with [docx,pdf] optional formats support
RUN pip install --no-cache-dir -e ./packages/markitdown[docx,pdf]

EXPOSE 8000

CMD uvicorn app:app --host 0.0.0.0 --port ${PORT:-8000}

